<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />

    <title>Page not found - SongRecommender</title>
  </head>
  <body>
    <div class="h-screen flex items-center justify-center">
      <div class="w-[50%] flex flex-col items-center">
        <section>
          Maybe you didn't mean to be here. Click the image below to continue listening
        </section>
        <.link href={~p"/"} class="w-[6rem] block">
          <img
            src={~p"/images/boy_listening.png"}
            alt="song image"
            class="w-full h-full object-cover"
          />
        </.link>
      </div>
    </div>
  </body>
</html>
